{
  "rewrites": [
    {
      "source": "/api(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!api|public|assets).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "node_modules/**|next-auth-system/**|prisma/**|src/**|dist/**|.git/**|.agents/**|public/**"
    }
  }
}
